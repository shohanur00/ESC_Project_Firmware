#include "main.h"

void App_Setup(void)
{
    // -----------------------------
    // Phase A → 20 kHz PWM, 20% duty
    // -----------------------------
    uint32_t arr  = htim1.Init.Period;        // TIM1 ARR (from CubeMX)
    uint32_t duty = arr / 5;                  // 20% duty → ARR / 5

    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);    // Phase A high-side ON
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_1);  // Phase A low-side OFF
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, duty);

    // -----------------------------
    // Phase B → OFF (Hi-Z)
    // -----------------------------
    HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_2);
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_2);

    // -----------------------------
    // Phase C → OFF (Hi-Z)
    // -----------------------------
    HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_3);
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_3);
}

void App_Main_Loop(void){

    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET);
    HAL_Delay(500);

    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);
    HAL_Delay(500);

    uint8_t msg[] = "Hello DMA UART3\r\n";

    if (huart3.gState == HAL_UART_STATE_READY)
    {
        HAL_UART_Transmit_DMA(&huart3, msg, sizeof(msg)-1);
    }

}
