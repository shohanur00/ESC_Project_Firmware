#include "main.h"

void App_Setup(void){
    uint32_t duty = htim1.Init.Period / 2;  // 50% duty

    // -------- Phase A → HIGH (PWM) --------
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_1);  // low side OFF
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, duty);

    // -------- Phase B → LOW (only low-side ON) --------
    HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_2);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2); // low side ON

    // -------- Phase C → OFF (Hi-Z) --------
    HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_3);
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_3);
}

void App_Main_Loop(void){
    // LED toggle non-blocking
    static uint32_t led_tick = 0;
    if(HAL_GetTick() - led_tick > 500){
        HAL_GPIO_TogglePin(LED_GPIO_Port, LED_Pin);
        led_tick = HAL_GetTick();
    }

    // UART DMA send once
    static uint8_t sent = 0;
    uint8_t msg[] = "Hello DMA UART3\r\n";
    if(!sent && huart3.gState == HAL_UART_STATE_READY){
        HAL_UART_Transmit_DMA(&huart3, msg, sizeof(msg)-1);
        sent = 1;
    }
}
