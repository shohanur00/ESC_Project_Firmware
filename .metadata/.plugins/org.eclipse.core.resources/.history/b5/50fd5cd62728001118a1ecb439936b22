#include "main.h"

#define PHASEA_DUTY  (htim1.Init.Period / 5)  // 20%
#define PHASEB_DUTY  (htim1.Init.Period / 3)  // 33%
#define PHASEC_DUTY  (htim1.Init.Period / 2)  // 50%

void App_Setup(void)
{
    // -------- Phase A PWM --------
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);      // High-side ON
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_1);   // Low-side OFF
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, PHASEA_DUTY);

    // -------- Phase B PWM --------
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);      // High-side ON
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_2);   // Low-side OFF
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, PHASEB_DUTY);

    // -------- Phase C PWM --------
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);      // High-side ON
    HAL_TIMEx_PWMN_Stop(&htim1, TIM_CHANNEL_3);   // Low-side OFF
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, PHASEC_DUTY);

    // -------- Enable Gate Driver --------
    HAL_GPIO_WritePin(EN_GATE_GPIO_Port, EN_GATE_Pin, GPIO_PIN_SET);
}

void App_Main_Loop(void){

    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET);
    HAL_Delay(500);

    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);
    HAL_Delay(500);

    uint8_t msg[] = "Hello DMA UART3\r\n";

    if (huart3.gState == HAL_UART_STATE_READY)
    {
        HAL_UART_Transmit_DMA(&huart3, msg, sizeof(msg)-1);
    }

}
